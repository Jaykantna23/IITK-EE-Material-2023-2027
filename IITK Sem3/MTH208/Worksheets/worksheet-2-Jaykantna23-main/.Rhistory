rho_mat = function(n ,rho)
{
mat4 = numeric(n*n)
for(i in 1:n)
{
for(j in 1:n)
{
mat4[i][j] = rho^abs(i-j)
}
}
mat4 = matrix(mat4, nrow = n, ncol = n)
}
rho_mat()

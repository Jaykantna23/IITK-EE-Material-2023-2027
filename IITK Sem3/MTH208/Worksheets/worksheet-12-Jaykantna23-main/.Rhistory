#Q5
packets = function()
{
count = 0
character = c("Harry", "Dumbledore", "Hermione", "Ron", "Neville", "Mcgonagall", "Dobby
")
collected_toy = character(0)
while(length(unique(collected_toy)) != length(character))
{
toy = sample(character, size = 1, prob = c(0.25, 0.20, 0.20, 0.15, 0.10, 0.05, 0.05))
collected_toy = c(collected_toy, toy)
count= count+1
}
return(count)
}
packets()
sum=0
for(i in 1:1000)
{
sum = sum+packets()
}
sum=sum/1000
sum

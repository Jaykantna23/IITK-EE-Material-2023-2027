smallWorld <- function(){
n.population <- 1e5
n.friends <- 150
n.encounters <- 500
days <- 0
IIT_friends <- 1:150
while(TRUE){
days <- days+1
r_people=sample(1:n.population,size=500,replace = TRUE)
meet_friend = sample(r_people,size=1)
if(meet_friend<=150 & meet_friend>=1){
break
}
}
return(days)
}
